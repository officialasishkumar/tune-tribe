TUNETRIBE_SECRET_KEY=replace-this-with-a-long-random-secret
TUNETRIBE_DATABASE_URL=postgresql+psycopg://tunetribe:change-me@localhost:5432/tunetribe
TUNETRIBE_DATABASE_AUTO_MIGRATE=true
TUNETRIBE_DATABASE_POOL_SIZE=10
TUNETRIBE_DATABASE_MAX_OVERFLOW=20
TUNETRIBE_DATABASE_POOL_RECYCLE_SECONDS=1800
TUNETRIBE_ACCESS_TOKEN_EXPIRE_MINUTES=43200
TUNETRIBE_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
TUNETRIBE_ALLOWED_HOSTS=localhost,127.0.0.1
TUNETRIBE_SEED_DEMO_DATA=false
