TUNETRIBE_SECRET_KEY=replace-this-with-a-long-random-secret
TUNETRIBE_DATABASE_URL=mysql+pymysql://tunetribe:change-me@localhost:3306/tunetribe?charset=utf8mb4
TUNETRIBE_DATABASE_AUTO_MIGRATE=true
TUNETRIBE_DATABASE_POOL_SIZE=10
TUNETRIBE_DATABASE_MAX_OVERFLOW=20
TUNETRIBE_DATABASE_POOL_RECYCLE_SECONDS=1800
TUNETRIBE_ACCESS_TOKEN_EXPIRE_MINUTES=1440
TUNETRIBE_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
TUNETRIBE_ALLOWED_HOSTS=localhost,127.0.0.1
TUNETRIBE_SEED_DEMO_DATA=false
TUNETRIBE_AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
TUNETRIBE_AUTH_RATE_LIMIT_WINDOW_SECONDS=300
TUNETRIBE_METADATA_HTTP_TIMEOUT_SECONDS=10.0
TUNETRIBE_METADATA_CACHE_TTL_SECONDS=86400
TUNETRIBE_METADATA_MEMORY_CACHE_MAX_ENTRIES=2048
TUNETRIBE_FORWARDED_ALLOW_IPS=
