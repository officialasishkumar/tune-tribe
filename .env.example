MYSQL_DATABASE=tunetribe
MYSQL_USER=tunetribe
MYSQL_PASSWORD=replace-with-a-strong-database-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-strong-root-password
TUNETRIBE_SECRET_KEY=replace-with-a-long-random-secret
TUNETRIBE_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
TUNETRIBE_ALLOWED_HOSTS=localhost,127.0.0.1,backend
TUNETRIBE_SEED_DEMO_DATA=false
TUNETRIBE_AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
TUNETRIBE_AUTH_RATE_LIMIT_WINDOW_SECONDS=300
TUNETRIBE_METADATA_HTTP_TIMEOUT_SECONDS=10.0
TUNETRIBE_METADATA_CACHE_TTL_SECONDS=86400
TUNETRIBE_METADATA_MEMORY_CACHE_MAX_ENTRIES=2048
TUNETRIBE_WEB_CONCURRENCY=2
TUNETRIBE_FORWARDED_ALLOW_IPS=
VITE_API_BASE_URL=/api
